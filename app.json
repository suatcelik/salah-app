{
  "expo": {
    "name": "Salah - Namaz Vakitleri",
    "slug": "salah-namaz-app",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "salah",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A2A1E"
    },
    "ios": {
      "bundleIdentifier": "com.salahapp.namaz",
      "buildNumber": "1",
      "supportsTablet": false,
      "requireFullScreen": true,
      "backgroundColor": "#0A2A1E",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Doğru namaz vakitleri ve kıble yönü için konumunuza ihtiyaç duyulmaktadır.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Ezan alarmlarının doğru çalışması için konumunuza ihtiyaç duyulmaktadır.",
        "UIBackgroundModes": [
          "fetch",
          "remote-notification"
        ],
        "CFBundleAllowMixedLocalizations": true,
        "CFBundleDevelopmentRegion": "tr"
      }
    },
    "android": {
      "package": "com.salahapp.namaz",
      "versionCode": 1,
      "compileSdkVersion": 34,
      "targetSdkVersion": 34,
      "minSdkVersion": 24,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A2A1E"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.WAKE_LOCK",
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Amiri-Regular.ttf",
            "./assets/fonts/Amiri-Bold.ttf",
            "./assets/fonts/Outfit-Regular.ttf",
            "./assets/fonts/Outfit-Medium.ttf",
            "./assets/fonts/Outfit-SemiBold.ttf",
            "./assets/fonts/Outfit-Bold.ttf",
            "./assets/fonts/Outfit-ExtraBold.ttf"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Namaz vakitleri için konum izni gereklidir.",
          "isIosBackgroundLocationEnabled": false,
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#C9A84C",
          "defaultChannel": "ezan",
          "sounds": [
            "./assets/sounds/ezan.wav",
            "./assets/sounds/reminder.wav"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "15.1",
            "useFrameworks": "static"
          },
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 24,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true
          }
        }
      ]
    ],
    "newArchEnabled": true,
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 3000,
      "url": "https://u.expo.dev/6eca5e5f-44ec-49c2-a20e-5032c50fcfe0"
    },
    "extra": {
      "eas": {
        "projectId": "6eca5e5f-44ec-49c2-a20e-5032c50fcfe0"
      },
      "aladhanApiUrl": "https://api.aladhan.com/v1",
      "supportEmail": "support@salahapp.com"
    }
  }
}