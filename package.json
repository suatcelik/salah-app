{
  "name": "salah-namaz-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build --profile preview --platform all",
    "build:prod": "eas build --profile production --platform all",
    "submit:ios": "eas submit --platform ios",
    "submit:android": "eas submit --platform android",
    "submit:all": "eas submit --platform all",
    "update": "eas update --auto",
    "update:prod": "eas update --channel production --message",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.0.0",
    "expo": "^55.0.8",
    "expo-application": "~55.0.10",
    "expo-asset": "~55.0.10",
    "expo-build-properties": "~55.0.10",
    "expo-device": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-linear-gradient": "~55.0.9",
    "expo-localization": "~55.0.9",
    "expo-location": "~55.1.4",
    "expo-notifications": "~55.0.13",
    "expo-router": "~55.0.7",
    "expo-sensors": "~55.0.9",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "expo-store-review": "~55.0.9",
    "expo-updates": "~55.0.15",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^9.0.0",
    "typescript": "^5.3.3"
  }
}
