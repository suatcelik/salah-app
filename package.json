{
  "name": "salah-namaz-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build:dev": "eas build --profile development",
    "build:preview": "eas build --profile preview --platform all",
    "build:prod": "eas build --profile production --platform all",
    "submit:ios": "eas submit --platform ios",
    "submit:android": "eas submit --platform android",
    "submit:all": "eas submit --platform all",
    "update": "eas update --auto",
    "update:prod": "eas update --channel production --message",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.1.0",
    "@tanstack/react-query": "^5.0.0",
    "expo": "~52.0.0",
    "expo-application": "~6.0.0",
    "expo-asset": "~11.0.5",
    "expo-build-properties": "~0.13.0",
    "expo-device": "~6.0.0",
    "expo-font": "~13.0.0",
    "expo-linear-gradient": "~14.0.0",
    "expo-localization": "~15.0.0",
    "expo-location": "~17.0.0",
    "expo-notifications": "~0.29.0",
    "expo-router": "~4.0.0",
    "expo-sensors": "~14.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-status-bar": "~2.0.0",
    "expo-store-review": "~7.0.0",
    "expo-updates": "~0.26.0",
    "react": "18.3.1",
    "react-native": "0.76.5",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-reanimated": "~3.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.1.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^9.0.0",
    "typescript": "^5.3.3"
  }
}
